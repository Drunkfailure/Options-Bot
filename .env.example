# Alpaca API (get keys from https://app.alpaca.markets)
ALPACA_API_KEY_ID=your_key_id
ALPACA_SECRET_KEY=your_secret_key

# Data API: quotes, trades, historical bars. Paper keys often work with data.alpaca.markets; if you get 401 try that.
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
# Trading API: account, portfolio, orders (paper = sandbox, live = production)
ALPACA_TRADING_BASE_URL=https://paper-api.alpaca.markets
